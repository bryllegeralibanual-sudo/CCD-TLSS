    <tr><td style="color:var(--color-text-secondary);padding:3px 0;width:110px">Type</td><td>${isLab?'<span class="split-badge lab">Lab slot</span>':'<span class="split-badge lec">Lecture slot</span>'}</td></tr>
    <tr><td style="color:var(--color-text-secondary);padding:3px 0">Subject</td><td style="font-weight:500">${e.code} – ${e.title}</td></tr>
    <tr><td style="color:var(--color-text-secondary);padding:3px 0">Section</td><td style="font-weight:500">${e.section}</td></tr>
    <tr><td style="color:var(--color-text-secondary);padding:3px 0">Year strategy</td><td>${getYearSlotRule(e.yr||1).label}</td></tr>
    <tr><td style="color:var(--color-text-secondary);padding:3px 0">Faculty</td><td>${e.facName}</td></tr>
    <tr><td style="color:var(--color-text-secondary);padding:3px 0">Day & time</td><td style="font-weight:500">${e.day}, ${scheduleTimeRange(e)}</td></tr>
    <tr><td style="color:var(--color-text-secondary);padding:3px 0">Duration</td><td>${scheduleHours(e)} hours</td></tr>
    <tr><td style="color:var(--color-text-secondary);padding:3px 0">Room</td><td>${e.room}</td></tr>
    <tr><td style="color:var(--color-text-secondary);padding:3px 0">Room type needed</td><td>${e.rtype}</td></tr>
    <tr><td style="color:var(--color-text-secondary);padding:3px 0">Lec units</td><td>${e.lec}</td></tr>
    <tr><td style="color:var(--color-text-secondary);padding:3px 0">Lab units</td><td>${e.lab}</td></tr>
    ${isLab?`<tr><td style="color:var(--color-text-secondary);padding:3px 0">Lab hours</td><td>${labHours} hours</td></tr>`:''}
  </table>`;
  openModal('modal-block');
}

function populateManualModal(){
  document.getElementById('manual-entry').innerHTML=db.schedules.map(s=>`<option value="${s.id}">${s.code} [${s.slotType||'lec'}] – ${s.section} (${s.day} ${scheduleTimeRange(s)})</option>`).join('');
  document.getElementById('manual-time').innerHTML=SLOTS.map(s=>`<option>${s}</option>`).join('');
  document.getElementById('manual-room').innerHTML=db.rooms.map(r=>`<option>${r.name}</option>`).join('');
}
function applyManual(){
  const id=+document.getElementById('manual-entry').value;
  const e=db.schedules.find(s=>s.id===id);
  if(e){e.day=document.getElementById('manual-day').value;e.time=document.getElementById('manual-time').value;e.room=document.getElementById('manual-room').value;}
  closeModal('modal-manual');renderTimetable();updateMetrics();
}

/* ======================================================
   CONFLICT CHECKER — UPDATED FOR SPLIT SLOTS
====================================================== */
function checkConflicts(){
  const conflicts=[];
  const tm={};const rm={};const sm={};
  db.schedules.forEach(s=>{
    if(s.facName!=='TBA'){
      occupiedSlotLabels(s).forEach(slot=>{
        const tk=`${s.facName}|${s.day}|${slot}`;
        if(tm[tk])conflicts.push({type:'Teacher conflict',msg:`${s.facName} has two slots at ${s.day} ${slot}: "${tm[tk]}" and "${s.code} [${s.slotType||'lec'}]"`});
        else tm[tk]=`${s.code} [${s.slotType||'lec'}]`;
      });
    }
    if(s.room&&!s.room.startsWith('TBA')){
      occupiedSlotLabels(s).forEach(slot=>{
        const rk=`${s.room}|${s.day}|${slot}`;
        if(rm[rk])conflicts.push({type:'Room conflict',msg:`${s.room} is double-booked at ${s.day} ${slot}: "${rm[rk]}" and "${s.code} [${s.slotType||'lec'}]"`});
        else rm[rk]=`${s.code} [${s.slotType||'lec'}]`;
      });
    }
    occupiedSlotLabels(s).forEach(slot=>{
      const sk=`${s.section}|${s.day}|${slot}`;
      if(sm[sk])conflicts.push({type:'Section conflict',msg:`${s.section} has two slots at ${s.day} ${slot}: "${sm[sk]}" and "${s.code} [${s.slotType||'lec'}]"`});
      else sm[sk]=`${s.code} [${s.slotType||'lec'}]`;
    });
  });
  return conflicts;
}
function renderConflicts(){
  const el=document.getElementById('conflict-list');
  const conflicts=checkConflicts();
  if(!db.schedules.length){el.innerHTML='<div class="card" style="text-align:center;padding:40px"><i class="ti ti-calendar-off" style="font-size:32px;display:block;margin-bottom:8px;opacity:.3"></i><div style="color:var(--color-text-secondary)">No schedule generated yet. Use the Schedule Generator first.</div></div>';return;}
  if(!conflicts.length){el.innerHTML='<div class="card" style="text-align:center;padding:40px"><i class="ti ti-circle-check" style="font-size:36px;color:#3B6D11;display:block;margin-bottom:8px"></i><div style="font-weight:500;color:#3B6D11;font-size:15px">No conflicts detected</div><div style="font-size:13px;color:var(--color-text-secondary);margin-top:4px">The schedule is clean. You can proceed to publish.</div></div>';return;}
  el.innerHTML=`<div style="margin-bottom:12px;font-size:13px;font-weight:500;color:#A32D2D"><i class="ti ti-alert-triangle"></i> ${conflicts.length} conflict${conflicts.length>1?'s':''} found — resolve before publishing</div>`+
  conflicts.map(c=>`<div class="conflict-item"><i class="ti ti-alert-triangle" style="color:#A32D2D;font-size:16px;flex-shrink:0;margin-top:1px"></i><div><div style="font-size:12px;font-weight:600;color:#A32D2D;margin-bottom:2px">${c.type}</div><div style="font-size:13px">${c.msg}</div></div></div>`).join('');
  updateMetrics();
}

/* ======================================================
   PUBLISH
====================================================== */
function publishSchedule(){
  const coverage=getScheduleCoverage();
  if(coverage.missing.length){
    alert(`Cannot publish: ${coverage.missing.length} subject(s) are unscheduled or have no room assigned. Resolve them first.`);
    renderCoverageReport();return;
  }
  const conflicts=checkConflicts();
  if(conflicts.length>0&&!confirm(`There are ${conflicts.length} conflict(s). Publish anyway?`))return;
  // FIX: show correct AY and sem in publish confirmation
  const gen=db.lastGenerated||{};
  document.getElementById('publish-detail').textContent=`AY ${gen.ay||'2024–2025'} · ${semesterLabel(gen.sem||'1st')} schedule is now live and visible to faculty.`;
  document.getElementById('gen-step3').style.display='none';
  document.getElementById('gen-step4').style.display='';
  document.getElementById('gs3').classList.remove('active');document.getElementById('gs3').classList.add('done');
  document.getElementById('gs4').classList.add('active');
}
function resetGenerator(){
  document.getElementById('gen-step4').style.display='none';
  document.getElementById('gen-step1').style.display='';
  ['gs1','gs2','gs3','gs4'].forEach(id=>{document.getElementById(id).classList.remove('active','done');});
  document.getElementById('gs1').classList.add('active');
  document.getElementById('gen-prog-bar').style.width='0%';
  const coverage=document.getElementById('coverage-report');
  if(coverage)coverage.innerHTML='';
}

/* ======================================================
   REPORTS — WITH PRINT BUTTON
====================================================== */
function genReport(type){
  const el=document.getElementById('report-output');
  document.getElementById('report-print-bar').style.display='block'; // FIX: show print
  if(type==='load'){
    el.innerHTML=`<div class="card">
      <div class="card-header"><span class="card-title">Faculty load report — AY ${db.currentAY} · ${semesterLabel(db.currentSem)}</span></div>
      <table><thead><tr><th>Faculty</th><th>Program</th><th>Type</th><th>Subjects (this sem)</th><th>Units</th><th>Max</th><th>Status</th></tr></thead>
      <tbody>`+db.faculty.map(f=>{
      // FIX: filter by current semester
      const asgn=db.assignments.filter(a=>{
        if(a.facId!==f.id)return false;
        const sub=db.subjects.find(x=>x.id===a.subjId);
        return sub&&sub.sem===db.currentSem;
      });
      const units=getFacultyUnits(f.id,db.currentSem);
      const mx=getFacultyMaxUnits(f);
      const status=units===0?`<span class="badge badge-gray">Unassigned</span>`:units>mx?`<span class="badge badge-red">Overloaded</span>`:`<span class="badge badge-green">OK</span>`;
      return `<tr><td style="font-weight:500">${f.ln}, ${f.fn}</td><td><span class="badge ${PROG_BADGE[f.prog]||'badge-gray'}">${facultyProgramLabel(f)}</span></td><td>${f.type}</td><td style="text-align:center">${asgn.length}</td><td style="text-align:center;font-weight:500">${units}</td><td style="text-align:center">${mx}</td><td>${status}</td></tr>`;
    }).join('')+'</tbody></table></div>';
  } else if(type==='room'){
    const rh={};db.schedules.forEach(s=>{if(!s.room.startsWith('TBA'))rh[s.room]=(rh[s.room]||0)+scheduleHours(s);});
    el.innerHTML=`<div class="card">
      <div class="card-header"><span class="card-title">Room utilization report</span></div>
      <table><thead><tr><th>Room</th><th>Type</th><th>Program</th><th>Hours occupied</th><th>Utilization (of 50 hrs/wk)</th></tr></thead>
      <tbody>`+db.rooms.map(r=>{
      const hrs=rh[r.name]||0;const pct=Math.min(100,Math.round(hrs/50*100));
      return `<tr><td style="font-weight:500">${r.name}</td><td>${r.type}</td><td>${r.prog||'All'}</td><td>${hrs}h</td><td><div style="display:flex;align-items:center;gap:8px"><div class="load-bar" style="flex:1;max-width:120px"><div class="load-fill" style="width:${pct}%;background:#185FA5"></div></div><span style="font-size:12px;min-width:32px">${pct}%</span></div></td></tr>`;
    }).join('')+'</tbody></table></div>';
  } else {
    el.innerHTML=`<div class="card"><div class="card-header"><span class="card-title">Master schedule — AY ${db.lastGenerated?db.lastGenerated.ay:'2024–2025'} · ${semesterLabel(db.lastGenerated?db.lastGenerated.sem:'1st')}</span></div>`+
    (db.schedules.length
      ?`<div style="overflow-x:auto"><table><thead><tr><th>Code</th><th>Subject</th><th>Slot type</th><th>Program</th><th>Section</th><th>Year strategy</th><th>Faculty</th><th>Day</th><th>Time</th><th>Room</th><th>Room type</th></tr></thead><tbody>`+
        db.schedules.map(s=>`<tr>
          <td style="font-weight:500">${s.code}</td>
          <td>${s.title}</td>
          <td>${s.slotType==='lab'?'<span class="split-badge lab">Lab</span>':'<span class="split-badge lec">Lecture</span>'}</td>
          <td><span class="badge ${PROG_BADGE[s.prog]||'badge-gray'}">${s.prog}</span></td>
          <td>${s.section}</td>
          <td>${getYearSlotRule(s.yr||1).label}</td>
          <td>${s.facName}</td>
          <td>${s.day}</td>
          <td>${scheduleTimeRange(s)}</td>
          <td>${s.room}</td>
          <td>${s.rtype}</td>
        </tr>`).join('')+'</tbody></table></div>'
      :`<div class="empty-state"><i class="ti ti-calendar-off"></i>No schedule generated yet.</div>`)
    +`</div>`;
  }
}

/* ======================================================
   INIT
====================================================== */
updateMetrics();
</script>
