function getScheduleCoverage(){
  // FIX: use db.lastGenerated; never null-fallback to wrong semester
  if(!db.lastGenerated)return{sem:db.currentSem,expected:0,scheduled:0,missing:[]};
  const gen=db.lastGenerated;
  const sem=gen.sem;
  const secs=getSections().filter(sec=>!gen.prog||sec.prog===gen.prog);
  const missing=[];let expected=0;
  secs.forEach(sec=>{
    const required=db.subjects.filter(s=>s.prog===sec.prog&&s.yr===sec.yr&&s.sem===sem);
    expected+=required.length;
    required.forEach(subj=>{
      // A subject is considered "scheduled" if it has at least one slot (lecture or lab) in schedules
      const hasAny=db.schedules.some(s=>s.section===sec.full&&s.code.replace(/-L$/,'')===subj.code&&s.room!=='TBA (no room)'&&s.room!=='TBA (no lab room)');
      if(!hasAny)missing.push({section:sec.full,code:subj.code,title:subj.title,prog:sec.prog,yr:sec.yr});
    });
  });
  return{sem,expected,scheduled:expected-missing.length,missing};
}

function renderCoverageReport(){
  const el=document.getElementById('coverage-report');
  if(!el||!db.schedules.length){if(el)el.innerHTML='';return;}
  const cov=getScheduleCoverage();
  if(!cov.missing.length){
    el.innerHTML=`<div class="coverage-panel ok"><div class="coverage-title"><i class="ti ti-circle-check"></i>Curriculum coverage complete</div>All ${cov.expected} subject offering(s) are scheduled for ${semesterLabel(cov.sem)}.</div>`;return;
  }
  el.innerHTML=`<div class="coverage-panel warn"><div class="coverage-title"><i class="ti ti-alert-triangle"></i>Coverage incomplete — ${cov.missing.length} subject(s) missing or assigned to TBA room</div><ul>`+
    cov.missing.slice(0,12).map(m=>`<li><strong>${m.section}</strong> – ${m.code}: ${m.title}</li>`).join('')+
    (cov.missing.length>12?`<li>…and ${cov.missing.length-12} more</li>`:'')+
    `</ul></div>`;
}

