function findRoom(neededType, prog, usedRoomSlots, day, times){
  const neededTimes=Array.isArray(times)?times:[times];
  return db.rooms.find(r=>{
    if(r.type!==neededType)return false;
    if(r.prog&&r.prog!==prog)return false;
    return neededTimes.every(time=>!usedRoomSlots[`${r.name}|${day}|${time}`]);
  });
}

function generateSchedule(){
  db.schedules=[];
  db.roomTimetable={};  // FIX #3: Reset room timetable
  const secs=getSections();
  const sem=document.getElementById('gen-sem').value;
  const progFilter=document.getElementById('gen-prog').value;
  const genAY=document.getElementById('gen-ay').value;
  db.lastGenerated={sem,prog:progFilter,ay:genAY};

  let secList=progFilter?secs.filter(s=>s.prog===progFilter):secs;

  const teacherSlots={};  // `facId|day|time` → true
  const roomSlots={};     // `roomName|day|time` → true
  const sectionSlots={};  // `section|day|time` → true
  let uid=1;

  function tryAssignSlot(sec, subj, fac, neededRoomType, slotType, requiredHours=1, uid_ref, dayIndexes=null, startSlotIndex=null){
    const facKey=fac?fac.id:'NONE';
    const allowedSlots=getYearSlotIndexes(sec.yr);
    const candidateDays=dayIndexes||DAYS.map((_,idx)=>idx);
    for(const d of candidateDays){
      const dayKey=['mon','tue','wed','thu','fri','sat'][d];
      const candidateSlots=startSlotIndex===null?allowedSlots:[startSlotIndex];
      for(let si=0;si<candidateSlots.length;si++){
        const t=candidateSlots[si];
        if(!allowedSlots.includes(t))continue;
        const consecutiveSlots=slotsNeededForHours(t,allowedSlots,requiredHours);
        if(!consecutiveSlots)continue;
        // FIX #8: Check if enough consecutive slots available
        const slotsNeeded=[];
        let canUseConsecutive=true;
        for(let c=0;c<consecutiveSlots;c++){
          const slotIdx=allowedSlots.indexOf(t)+c;
          if(slotIdx>=allowedSlots.length){canUseConsecutive=false;break;}
          slotsNeeded.push(allowedSlots[slotIdx]);
        }
        if(!canUseConsecutive)continue;
        
        const isAM=t<3;
        // Check faculty availability for ALL needed slots
        if(fac){
          let freeForAll=true;
          for(let slot of slotsNeeded){
            if(!fac.avail[dayKey][slot<3?'am':'pm']){freeForAll=false;break;}
          }
          if(!freeForAll)continue;
        }
        
        // Check teacher time conflict for ALL needed slots
        let teacherFree=true;
        for(let slot of slotsNeeded){
          const tk=`${facKey}|${DAYS[d]}|${SLOTS[slot]}`;
          if(fac&&teacherSlots[tk]){teacherFree=false;break;}
        }
        if(!teacherFree)continue;
        
        // Check section time conflict for ALL needed slots
        let sectionFree=true;
        for(let slot of slotsNeeded){
          const sk=`${sec.full}|${DAYS[d]}|${SLOTS[slot]}`;
          if(sectionSlots[sk]){sectionFree=false;break;}
        }
        if(!sectionFree)continue;
        
        // Find room of needed type for the entire session.
        const room=findRoom(neededRoomType,subj.prog,roomSlots,DAYS[d],slotsNeeded.map(slot=>SLOTS[slot]));
        if(!room)continue;
        
        // All clear — book ALL slots
        if(fac)slotsNeeded.forEach(slot=>{teacherSlots[`${facKey}|${DAYS[d]}|${SLOTS[slot]}`]=true;});
        slotsNeeded.forEach(slot=>{
          roomSlots[`${room.name}|${DAYS[d]}|${SLOTS[slot]}`]=true;
          sectionSlots[`${sec.full}|${DAYS[d]}|${SLOTS[slot]}`]=true;
        });
        
        // FIX #3: Update room timetable
        const roomKey=room.name;
        if(!db.roomTimetable[roomKey])db.roomTimetable[roomKey]={};
        slotsNeeded.forEach(slot=>{
          const daySlotKey=`${DAYS[d]}|${SLOTS[slot]}`;
          db.roomTimetable[roomKey][daySlotKey]={code:subj.code,section:sec.full,faculty:fac?`${fac.ln}, ${fac.fn}`:'TBA'};
        });
        
        return {
          id:uid++,
          code:subj.code,
          title:subj.title,
          prog:sec.prog,
          section:sec.full,
          facName:fac?`${fac.ln}, ${fac.fn}`:'TBA',
          day:DAYS[d],
          time:SLOTS[t],
          room:room.name,
          lec:slotType==='lecture'?subj.lec:0,
          lab:slotType==='lab'?subj.lab:0,
          slotType, // 'lecture' or 'lab'
          rtype:neededRoomType,
          yr:sec.yr,
          sem,
          durationHours:requiredHours,
          consecutiveSlots // FIX #8: track how many slots used
        };
      }
    }
    return null; // could not find a slot
  }

  function releaseSlot(slot, fac){
    const facKey=fac?fac.id:'NONE';
    occupiedSlotLabels(slot).forEach(label=>{
      if(fac)delete teacherSlots[`${facKey}|${slot.day}|${label}`];
      delete roomSlots[`${slot.room}|${slot.day}|${label}`];
      delete sectionSlots[`${slot.section}|${slot.day}|${label}`];
      if(db.roomTimetable[slot.room])delete db.roomTimetable[slot.room][`${slot.day}|${label}`];
    });
  }

  function lectureDayPattern(units){
    if(units>=3)return [0,2,4];       // MWF
    if(units===2)return [1,3];        // TTh
    return [0];                       // single-unit lecture
  }

  function tryAssignLecturePattern(sec, subj, fac){
    const meetingDays=lectureDayPattern(subj.lec);
    const meetingHours=LECTURE_HOURS_PER_UNIT;
    const allowedSlots=getYearSlotIndexes(sec.yr);
    for(let si=0;si<allowedSlots.length;si++){
      const t=allowedSlots[si];
      const slotsForMeeting=slotsNeededForHours(t,allowedSlots,meetingHours);
      if(!slotsForMeeting)continue;

      const trialSlots=[];
      let allMeetingsFit=true;
      for(const d of meetingDays){
        const slot=tryAssignSlot(sec,subj,fac,subj.lecRoomType,'lecture',meetingHours,uid,[d],t);
        if(slot){
          trialSlots.push(slot);
        }else{
          allMeetingsFit=false;
        }
        if(!allMeetingsFit)break;
      }

      if(allMeetingsFit){
        return trialSlots.map(slot=>({
          ...slot,
          lec:LECTURE_HOURS_PER_UNIT,
          meetingPattern:meetingDays.map(d=>DAYS[d].slice(0,3)).join('/')
        }));
      }
      trialSlots.forEach(slot=>releaseSlot(slot,fac));
    }
    return null;
  }

  secList.forEach(sec=>{
    const progSubjs=db.subjects.filter(s=>s.prog===sec.prog&&s.yr===sec.yr&&s.sem===sem);
    progSubjs.forEach(subj=>{
      // FIX #6: Consider section-specific assignment
      const asgn=db.assignments.find(a=>a.subjId===subj.id && a.section===sec.full);
      const fac=asgn?db.faculty.find(f=>f.id===asgn.facId):null;

      // ============================================================
      // FIX #6 & #8: LECTURE + LAB SPLIT WITH MULTI-SLOT SUPPORT
      // If subject has lecture units → schedule 1 hour per lecture unit.
      // If subject has lab units → schedule consecutive 3-hour sessions.
      // Lecture units: 1 unit = 1 hr, 3 units = 3 hrs, etc.
      // Lab units: 1 unit = 3 hrs (2 slots), 2 units = 6 hrs (4 slots), etc.
      // ============================================================

      // 1. LECTURE SLOT
      if(subj.lec>0 && subj.lecRoomType){
        const slots=tryAssignLecturePattern(sec,subj,fac);
        if(slots){db.schedules.push(...slots);}
        else{
          const pattern=lectureDayPattern(subj.lec);
          pattern.forEach(d=>{
            db.schedules.push({
              id:uid++,code:subj.code,title:subj.title,prog:sec.prog,
              section:sec.full,facName:fac?`${fac.ln}, ${fac.fn}`:'TBA',
              day:DAYS[d],time:SLOTS[getYearSlotIndexes(sec.yr)[0]],room:'TBA (no room)',
              lec:LECTURE_HOURS_PER_UNIT,lab:0,slotType:'lecture',rtype:subj.lecRoomType,yr:sec.yr,sem,durationHours:LECTURE_HOURS_PER_UNIT,consecutiveSlots:1,
              meetingPattern:pattern.map(day=>DAYS[day].slice(0,3)).join('/')
            });
          });
        }
      }

      // FIX #8: LAB SLOT(S) — each lab unit = 3 hrs = 2 consecutive 1.5 hr slots
      if(subj.lab>0 && subj.labRoomType){
        const labHours=subj.lab*LAB_HOURS_PER_UNIT;
        const slot=tryAssignSlot(sec,subj,fac,subj.labRoomType,'lab',labHours,uid);
        if(slot){db.schedules.push(slot);}
        else{
          const fallbackSlots=slotsNeededForHours(getYearSlotIndexes(sec.yr)[0],getYearSlotIndexes(sec.yr),labHours)||1;
          db.schedules.push({
            id:uid++,code:subj.code+'-L',title:subj.title+' (Lab)',prog:sec.prog,
            section:sec.full,facName:fac?`${fac.ln}, ${fac.fn}`:'TBA',
            day:'Tuesday',time:SLOTS[getYearSlotIndexes(sec.yr)[0]],room:'TBA (no lab room)',
            lec:0,lab:subj.lab,slotType:'lab',rtype:subj.labRoomType,yr:sec.yr,sem,durationHours:labHours,consecutiveSlots:fallbackSlots
          });
        }
      }
    });
  });

  document.getElementById('gen-step2').style.display='none';
  document.getElementById('gen-step3').style.display='';
  document.getElementById('gs2').classList.remove('active');document.getElementById('gs2').classList.add('done');
  document.getElementById('gs3').classList.add('active');
  updateSectionFilter();renderTimetable();renderRoomTimetable();
  updateMetrics();
}

