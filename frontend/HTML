// FIX: NEW — render ALL subjects (assigned + unassigned) organized by PROGRAM → SECTION with completion indicators and STICKY TEACHER AREA
function renderLoadSubjects(){
  const prog=document.getElementById('load-prog-filter').value;
  const sem=document.getElementById('load-sem-filter').value;
  
  // Get all sections, optionally filtered by program
  let sections=getSections();
  if(prog)sections=sections.filter(sec=>sec.prog===prog);
  
  // Get all subjects for the selected semester
  let allSubjs=db.subjects.filter(s=>s.sem===sem);
  if(prog)allSubjs=allSubjs.filter(s=>s.prog===prog);
  
  const el=document.getElementById('load-subject-list');
  
  // Get available teachers
  const teachers=db.faculty.filter(f=>!prog||canTeachProgram(f,prog));
  const trayHtml=`<div class="teacher-chip-list" style="margin-bottom:0;padding:0;display:flex;flex-wrap:wrap;gap:8px">`+teachers.map(f=>{
    const codes=getTeacherSubjectCodes(f.id);
    const codeCount=codes.size;
    const codeLabel=codeCount===0?'':'('+codeCount+'/3 codes)';
    return `<div class="teacher-chip" draggable="true" ondragstart="startTeacherDrag(event,${f.id})" title="${f.ln}: ${codeCount} unique subject codes"><i class="ti ti-user"></i><span style="font-size:11px">${f.ln} ${codeLabel}</span></div>`;
  }).join('')+'</div>';
  
  // Group subjects by Program → Section — SHOW ALL (assigned + unassigned)
  const programsOrder=db.programs.map(p=>p.code);
  const grouped=programsOrder.map(progCode=>{
    const progSections=sections.filter(sec=>sec.prog===progCode);
    if(!progSections.length)return '';
    
    const meta=PROGRAM_META[progCode]||{label:progCode,name:progCode};
    let progHtml=`<div style="margin-bottom:16px"><div style="font-size:13px;font-weight:600;margin-bottom:8px;display:flex;align-items:center;gap:6px"><span class="badge ${PROG_BADGE[progCode]||'badge-gray'}">${meta.label}</span><span style="font-size:11px;color:var(--color-text-secondary)">${progSections.length} section${progSections.length!==1?'s':''}</span></div>`;
    
    // For each section in this program
    progHtml+=progSections.map(sec=>{
      const secSubjs=allSubjs.filter(s=>s.prog===sec.prog&&s.yr===sec.yr);
      if(!secSubjs.length)return '';
      
      // Count assigned vs total — SECTION-SPECIFIC
      const assigned=secSubjs.filter(s=>subjectFaculty(s.id, sec.full).length>0).length;
      const total=secSubjs.length;
      const complete=assigned===total;
      const completeBadge=complete
        ?`<span class="section-completion complete"><i class="ti ti-circle-check"></i> Complete</span>`
        :`<span class="section-completion partial">${assigned}/${total}</span>`;
      
      return `<div class="load-group" style="margin-bottom:12px">
        <div class="load-group-title" style="display:flex;align-items:center;justify-content:space-between">
          <span><i class="ti ti-folder-open"></i> ${sec.full}</span>
          <div style="display:flex;align-items:center;gap:6px"><span style="font-size:11px;color:var(--color-text-secondary)">${total} subject${total!==1?'s':''}</span>${completeBadge}</div>
        </div>
        <table><thead><tr><th>Code</th><th>Subject</th><th>Units</th><th>Lec/Lab</th><th>Assigned to</th><th>Assign</th></tr></thead><tbody>`+
        secSubjs.map(s=>{
          const teachers_=subjectFaculty(s.id, sec.full);
          const isAssigned=teachers_.length>0;
          const assignedNames=teachers_.map(t=>t.ln).join(', ');
          return `<tr class="subject-row${isAssigned?' assigned':''}">
            <td style="font-weight:500;font-size:12px">${s.code}</td>
            <td style="font-size:12px">${s.title}</td>
            <td style="text-align:center;font-size:12px;font-weight:500">${s.lec+s.lab}</td>
            <td style="font-size:10px;text-align:center"><span class="split-badge lec">${s.lec}L</span>${s.lab>0?'<span class="split-badge lab">'+s.lab+'Lab</span>':''}</td>
            <td style="font-size:11px;color:${isAssigned?'#3B6D11':'var(--color-text-tertiary)'}"><i class="ti ti-${isAssigned?'circle-check':'circle'}"></i> ${isAssigned?'<strong>'+assignedNames+'</strong>':'—'}</td>
            <td><div class="subject-drop-cell" ondragover="handleSubjectDragOver(event,${s.id})" ondragleave="clearSubjectDrop(event)" ondrop="dropTeacherOnSubject(event,${s.id},'${sec.full}')" style="min-width:90px;padding:4px 8px;font-size:10px;color:var(--color-text-secondary);background:var(--color-background-secondary);border-radius:4px;text-align:center">Drop here</div></td>
          </tr>`;
        }).join('')+`</tbody></table></div>`;
    }).join('')+'</div>';
    
    return progHtml;
  }).join('');
  
  const totalSubjs=allSubjs.length;
  const totalAssigned=allSubjs.filter(s=>subjectFaculty(s.id).length>0).length;
  
  // FIX: Put teacher tray in sticky header, content in scrollable body
  document.querySelector('.load-subjects-head').innerHTML=`
    <div class="load-panel-head" style="margin:0;padding:0;display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:8px">
      <div class="load-panel-title"><i class="ti ti-list-check"></i>All subjects by section</div>
      <span style="font-size:11px;color:var(--color-text-secondary)">Drag a teacher chip onto a row to assign • Assigned subjects stay visible</span>
    </div>
    <div style="font-size:12px;color:var(--color-text-secondary);padding:8px;background:var(--color-background-secondary);border-radius:4px"><i class="ti ti-info-circle"></i> ${totalAssigned}/${totalSubjs} subjects assigned for ${semesterLabel(sem)}</div>
    <div class="load-teacher-tray-sticky">${trayHtml}</div>
  `;
  
  document.querySelector('.load-subjects-body').innerHTML=`<div class="load-subjects-inner">`+grouped+`</div>`;
}

function renderLoadDetail(){
  const id=+document.getElementById('load-fac-select').value;
  const sem=document.getElementById('load-sem-filter').value; // FIX: filter by semester
  const area=document.getElementById('load-detail-area');
  if(!id){area.innerHTML='<div class="empty-state"><i class="ti ti-user"></i>Select a faculty member to view their assigned subjects</div>';return;}
  const fac=db.faculty.find(f=>f.id===id);
  // FIX: filter assignments by semester
  const asgn=db.assignments.filter(a=>{
    if(a.facId!==id)return false;
    const sub=db.subjects.find(x=>x.id===a.subjId);
    return sub&&sub.sem===sem;
  });
  const mx=getFacultyMaxUnits(fac);
  const total=asgn.reduce((s,a)=>{const sub=db.subjects.find(x=>x.id===a.subjId);return s+(sub?sub.lec+sub.lab:0)},0);
  const pct=Math.min(100,Math.round(total/mx*100));
  const overload=total>mx;
  const barColor=overload?'#A32D2D':pct>85?'#854F0B':'#3B6D11';
  
  // FIX: Show subject code diversity
  const subjectCodes=getTeacherSubjectCodes(id);
  const codeCount=subjectCodes.size;
  const codeStatus=codeCount===0?'No assignments':'<strong>'+codeCount+'/3</strong> subject codes';
  const codeStatusColor=codeCount>3?'#A32D2D':(codeCount>2?'#854F0B':'#3B6D11');
  
  const unitMsg=overload
    ?`<div class="unit-error"><i class="ti ti-alert-triangle"></i> Overloaded: ${total}/${mx} units this semester. Remove assignments to resolve.</div>`
    :pct>85
    ?`<div class="unit-warn"><i class="ti ti-alert-circle"></i> Near limit: ${total}/${mx} units this semester.</div>`
    :`<div class="unit-ok"><i class="ti ti-circle-check"></i> ${total}/${mx} units this semester — within limit.</div>`;
  
  if(!asgn.length){
    area.innerHTML='<div style="padding:14px">'+unitMsg+'<div style="padding:8px;margin-top:8px;background:var(--color-background-secondary);border-radius:4px;font-size:12px;color:var(--color-text-secondary)"><i class="ti ti-info-circle"></i> Subject codes: '+codeStatus+'</div><div class="empty-state" style="padding:24px 0"><i class="ti ti-briefcase"></i>'+fac.ln+' has no assigned subjects for '+semesterLabel(sem)+'.<br><button class="btn btn-primary btn-sm" style="margin-top:12px" onclick="openAssignModal('+fac.id+')"><i class="ti ti-plus"></i>Assign subject</button></div></div>';
    return;
  }
  
  // Group by Program → Section (not year/semester) — with SECTION-SPECIFIC filtering
  const sections=getSections();
  const groupedRows=sections.map(sec=>{
    const rowsInSec=asgn.filter(a=>{
      const s=db.subjects.find(x=>x.id===a.subjId);
      return s&&s.prog===sec.prog&&s.yr===sec.yr&&a.section===sec.full;
    });
    if(!rowsInSec.length)return '';
    return `<div class="load-group">
      <div class="load-group-title"><span><i class="ti ti-folder-open"></i> ${sec.full}</span><span>${rowsInSec.length} subject${rowsInSec.length!==1?'s':''}</span></div>
      <table><thead><tr><th>Code</th><th>Subject title</th><th>Lec</th><th>Lab</th><th>Units</th><th></th></tr></thead><tbody>`+
      rowsInSec.map(a=>{
        const s=db.subjects.find(x=>x.id===a.subjId);if(!s)return'';
        return `<tr><td style="font-weight:500">${s.code}</td><td>${s.title}</td><td style="text-align:center">${s.lec}</td><td style="text-align:center">${s.lab}</td><td style="text-align:center;font-weight:500">${s.lec+s.lab}</td><td><button class="btn btn-sm btn-danger" onclick="removeAssign(${a.id})"><i class="ti ti-trash"></i></button></td></tr>`;
      }).join('')+'</tbody></table></div>';
  }).join('');
  
  area.innerHTML=`<div style="padding:12px 16px;border-bottom:0.5px solid var(--color-border-tertiary)">
    <div style="display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap">
      <div><span style="font-size:13px;font-weight:500">${fac.ln}, ${fac.fn}</span><div style="font-size:11px;color:var(--color-text-secondary);margin-top:1px">${semesterLabel(sem)} · ${fac.spec||'No specialization listed'}</div></div>
      <div style="text-align:right"><div style="font-size:12px"><strong>${total}</strong>/${mx} units</div><div style="font-size:11px;color:var(--color-text-secondary);margin-top:2px">${codeStatus}</div></div>
    </div>
    <div class="load-bar" style="margin-top:6px"><div class="load-fill" style="width:${pct}%;background:${barColor}"></div></div>
    ${unitMsg}
    <div style="padding:8px;margin-top:8px;background:${codeStatusColor}20;border:0.5px solid ${codeStatusColor}40;border-radius:4px;font-size:12px;color:${codeStatusColor}"><i class="ti ti-info-circle"></i> Subject codes: <strong>${Array.from(subjectCodes).join(', ')||'None'}</strong> (${codeCount}/3)</div>
  </div>
  <div style="padding:12px 16px">${groupedRows}</div>`;
}

function openAssignModal(facId){
  const selected=facId?db.faculty.find(f=>f.id===facId):db.faculty.find(f=>f.id==document.getElementById('load-fac-select').value);
  openModal('modal-assign');
