====================================================== */
const DAYS=['Monday','Tuesday','Wednesday','Thursday','Friday'];
const SLOTS=['7:30–9:00','9:00–10:30','10:30–12:00','1:00–2:30','2:30–4:00','4:00–5:00','5:00–6:30','6:30–8:00','8:00–9:30'];
const LECTURE_HOURS_PER_UNIT=1;
const LAB_HOURS_PER_UNIT=3;

function parseSlotTime(text){
  const m=text.trim().match(/^(\d{1,2}):(\d{2})$/);
  if(!m)return 0;
  let h=+m[1],min=+m[2];
  if(h<7)h+=12;
  return h+min/60;
}
function formatHourTime(value){
  let h=Math.floor(value);
  const min=Math.round((value-h)*60);
  h=((h-1)%12)+1;
  return `${h}:${String(min).padStart(2,'0')}`;
}
function slotStartTime(slotLabel){
  return slotLabel.split('–')[0]||slotLabel.split('-')[0]||slotLabel;
}
function slotEndTime(slotLabel){
  return slotLabel.split('–')[1]||slotLabel.split('-')[1]||slotLabel;
}
function slotDuration(slotLabel){
  return parseSlotTime(slotEndTime(slotLabel))-parseSlotTime(slotStartTime(slotLabel));
}
function scheduleTimeRange(entry){
  const startIdx=SLOTS.indexOf(entry.time);
  if(startIdx<0)return entry.time;
  const start=slotStartTime(entry.time);
  if(entry.durationHours)return `${start}–${formatHourTime(parseSlotTime(start)+entry.durationHours)}`;
  const slots=Math.max(1,entry.consecutiveSlots||1);
  const endIdx=Math.min(SLOTS.length-1,startIdx+slots-1);
  return `${start}–${slotEndTime(SLOTS[endIdx])}`;
}
function scheduleHours(entry){
  if(entry.durationHours)return entry.durationHours;
  return occupiedSlotLabels(entry).reduce((total,slot)=>total+slotDuration(slot),0);
}
function occupiedSlotLabels(entry){
  const startIdx=SLOTS.indexOf(entry.time);
  if(startIdx<0)return [entry.time];
  const slots=Math.max(1,entry.consecutiveSlots||1);
  return SLOTS.slice(startIdx,Math.min(SLOTS.length,startIdx+slots));
}
function slotsNeededForHours(startSlotIndex, allowedSlots, requiredHours){
  let hours=0;
  let count=0;
  const startPos=allowedSlots.indexOf(startSlotIndex);
  if(startPos<0)return 0;
  for(let i=startPos;i<allowedSlots.length&&hours<requiredHours;i++){
    hours+=slotDuration(SLOTS[allowedSlots[i]]);
    count++;
  }
  return hours>=requiredHours?count:0;
}

