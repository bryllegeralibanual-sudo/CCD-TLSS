// FIX #2: Edit year-level time slot configuration
function editYearSlots(yr){
  const rule=YEAR_SLOT_RULES[yr];
  const yearLabels=['','First Year','Second Year','Third Year','Fourth Year'];
  let html=`<div style="padding:14px">
    <div style="font-size:13px;font-weight:600;margin-bottom:12px">${yearLabels[yr]} — Time block configuration</div>
    <div class="form-group">
      <label class="form-label">Block label</label>
      <input id="edit-yr-label" value="${rule.label}" placeholder="e.g. Morning schedule">
    </div>
    <div class="form-group">
      <label class="form-label">Block description</label>
      <input id="edit-yr-detail" value="${rule.detail}" placeholder="e.g. 7:30 AM – 12:00 PM">
    </div>
    <div class="form-group">
      <label class="form-label">Available time slots (select multiple)</label>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:6px">`;
  SLOTS.forEach((slot,idx)=>{
    const checked=rule.slots.includes(idx);
    html+=`<label style="display:flex;align-items:center;gap:6px;padding:6px 8px;background:var(--color-background-secondary);border-radius:4px;cursor:pointer">
      <input type="checkbox" class="edit-slot-check" value="${idx}" ${checked?'checked':''}>
      <span style="font-size:12px">${slot}</span>
    </label>`;
  });
  html+=`</div></div><div style="padding:8px;background:#E6F1FB;border-radius:4px;font-size:11px;color:#185FA5"><i class="ti ti-info-circle"></i> Select which time slots this year level should use during schedule generation.</div></div>`;
  document.getElementById('year-slots-editor').innerHTML=html;
  document.getElementById('modal-edit-year-slots').classList.add('open');
  window.editingYear=yr;
}

function saveYearSlots(){
  const yr=window.editingYear;
  const label=document.getElementById('edit-yr-label').value.trim();
  const detail=document.getElementById('edit-yr-detail').value.trim();
  const slots=Array.from(document.querySelectorAll('.edit-slot-check:checked')).map(e=>+e.value);
  if(!label||!detail||!slots.length){alert('Please fill in all fields and select at least one time slot.');return;}
  YEAR_SLOT_RULES[yr]={label,detail,slots};
  // Update UI labels
  document.getElementById(`y${yr}-label`).textContent=label;
  document.getElementById(`y${yr}-detail`).textContent=detail;
  closeModal('modal-edit-year-slots');
}

// FIX: get assignments filtered by semester AND section
function subjectFaculty(subjId, section=''){
  return db.assignments
    .filter(a=>a.subjId===subjId && (!section || a.section===section))
    .map(a=>db.faculty.find(f=>f.id===a.facId))
    .filter(Boolean);
}

// FIX: assignments stats filtered by semester
function assignmentStats(subjects,sem=''){
  const list=sem?subjects.filter(s=>s.sem===sem):subjects;
  const assigned=list.filter(s=>subjectFaculty(s.id).length).length;
  return {assigned,total:list.length,missing:list.length-assigned};
}
function assignmentBadge(subjects,sem=''){
  const st=assignmentStats(subjects,sem);
  if(!st.total)return '<span class="badge badge-gray">No subjects</span>';
  if(!st.missing)return '<span class="badge badge-green"><i class="ti ti-circle-check"></i> All assigned</span>';
  return '<span class="badge badge-amber"><i class="ti ti-alert-circle"></i> '+st.missing+' need teacher</span>';
}

// FIX: get teacher unit load filtered by semester (section-independent for unit counting)
function getFacultyUnits(facId, sem=''){
  return db.assignments
    .filter(a=>a.facId===facId)
    .reduce((s,a)=>{
      const sub=db.subjects.find(x=>x.id===a.subjId);
      if(!sub)return s;
      if(sem && sub.sem!==sem)return s;
      return s+(sub.lec+sub.lab);
    },0);
}
function getFacultyMaxUnits(fac){return fac.maxUnits||MAX_UNITS[fac.type]||21;}

// FIX: Count unique subject codes a teacher teaches across all assignments
function getTeacherSubjectCodes(facId){
  const codes=new Set();
  db.assignments.filter(a=>a.facId===facId).forEach(a=>{
    const subj=db.subjects.find(x=>x.id===a.subjId);
    if(subj)codes.add(subj.code);
  });
  return codes;
}

