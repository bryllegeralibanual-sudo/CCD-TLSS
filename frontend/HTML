function checkAssignCompat(){
  const fId=+document.getElementById('assign-fac').value;
  const sId=+document.getElementById('assign-subj').value;
  const fac=db.faculty.find(f=>f.id===fId);
  const subj=db.subjects.find(s=>s.id===sId);
  const el=document.getElementById('assign-check');
  const btn=document.getElementById('assign-save-btn');
  assignBlocked=false;
  if(!fac||!subj){el.innerHTML='<div style="color:var(--color-text-secondary)">Select a program, faculty, and subject.</div>';if(btn)btn.disabled=false;return;}
  const notes=[];
  
  // 1. Check program compatibility
  if(!canTeachProgram(fac,subj.prog)){
    notes.push('<div class="unit-error"><i class="ti ti-x"></i> Program mismatch: '+fac.ln+' cannot teach '+programName(subj.prog)+' subjects.</div>');
    assignBlocked=true;
  }
  
  // FIX #1: Check specialization matching
  const specMatch=fac.spec && subj.code && fac.spec.toLowerCase().includes(subj.code.substring(0,2).toLowerCase());
  if(!specMatch && fac.spec){
    notes.push('<div class="unit-warn"><i class="ti ti-alert-circle"></i> Specialization mismatch: '+fac.ln+' teaches "'+fac.spec+'" but this subject is "'+subj.title+'". Assignment allowed but not ideal.</div>');
  } else if(specMatch){
    notes.push('<div class="unit-ok"><i class="ti ti-circle-check"></i> Specialization match: '+fac.spec+'</div>');
  }
  
  // 2. Check unit cap (18 units max)
  const curUnits=getFacultyUnits(fId,subj.sem);
  const mx=getFacultyMaxUnits(fac);
  const after=curUnits+subj.lec+subj.lab;
  if(after>mx){
    notes.push('<div class="unit-error"><i class="ti ti-alert-triangle"></i> Exceeds unit cap: '+after+'/'+mx+' units in '+semesterLabel(subj.sem)+'.</div>');
    assignBlocked=true;
  } else if(after>mx*0.85){
    notes.push('<div class="unit-warn"><i class="ti ti-alert-circle"></i> Near limit: '+after+'/'+mx+' units after this assignment.</div>');
  } else {
    notes.push('<div class="unit-ok"><i class="ti ti-circle-check"></i> Units OK: '+after+'/'+mx+' in '+semesterLabel(subj.sem)+'.</div>');
  }
  
  // FIX #5: Check subject code diversity (max 3 different subject codes) — FIXED LOGIC
  const currentCodes=getTeacherSubjectCodes(fId);
  // Check if NEW subject code is already in the list
  const isNewCode=!currentCodes.has(subj.code);
  const wouldHave=isNewCode?currentCodes.size+1:currentCodes.size;
  if(wouldHave>3){
    notes.push('<div class="unit-error"><i class="ti ti-alert-triangle"></i> Subject code limit exceeded: '+fac.ln+' would teach '+wouldHave+' different subject codes (max 3). Current: '+Array.from(currentCodes).join(', ')+'. New: '+subj.code+'</div>');
    assignBlocked=true;
  } else {
    const codeList=Array.from(currentCodes);if(isNewCode)codeList.push(subj.code);
    const codeMsg=wouldHave===0?'First assignment':`${wouldHave}/3 codes (${codeList.join(', ')})`;
    notes.push('<div class="unit-ok"><i class="ti ti-circle-check"></i> Subject code diversity OK: '+codeMsg+'</div>');
  }
  
  // 4. Check if already assigned
  if(db.assignments.find(a=>a.facId===fId&&a.subjId===sId)){
    notes.push('<div class="unit-error"><i class="ti ti-alert-triangle"></i> Already assigned.</div>');
    assignBlocked=true;
  }
  
  if(btn)btn.disabled=assignBlocked;
  if(btn)btn.style.opacity=assignBlocked?'0.5':'1';
  el.innerHTML=notes.join('');
}
function saveAssignment(){
  if(assignBlocked){alert('Cannot assign — resolve the issues shown.');return;}
  const facId=+document.getElementById('assign-fac').value;
  const subjId=+document.getElementById('assign-subj').value;
