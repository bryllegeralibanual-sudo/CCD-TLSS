    <td style="text-align:center;font-weight:500">${s.lec+s.lab}</td>
    <td><button class="btn btn-sm btn-danger" onclick="deleteSubject(${s.id})"><i class="ti ti-trash"></i></button></td>
  </tr>`;
  }).join('')+'</tbody></table>';
}

function renderCurriculum(){
  const prog=document.getElementById('cur-prog-filter').value;
  const yr=document.getElementById('cur-yr-filter').value;
  const sem=document.getElementById('cur-sem-filter').value;
  let list=db.subjects;
  if(prog)list=list.filter(s=>s.prog===prog);
  if(yr)list=list.filter(s=>s.yr==yr);
  if(sem)list=list.filter(s=>s.sem===sem);
  const tb=document.getElementById('curr-table');
  if(!list.length){tb.innerHTML='<div class="card" style="text-align:center;padding:32px;color:var(--color-text-secondary)">No subjects found.</div>';return;}
  const progOrder=db.programs.map(p=>p.code);
  const semOrder=['1st','2nd','Summer'];
  const programs=[...new Set(list.map(s=>s.prog))].sort((a,b)=>progOrder.indexOf(a)-progOrder.indexOf(b));
  tb.innerHTML=programs.map(code=>{
    const meta=PROGRAM_META[code]||{label:code,name:code};
    const byProgram=list.filter(s=>s.prog===code);
    const years=[...new Set(byProgram.map(s=>s.yr))].sort((a,b)=>a-b);
    return '<div class="curr-folder"><div class="curr-folder-head"><div class="curr-folder-title"><i class="ti ti-folder"></i><span class="badge '+(PROG_BADGE[code]||'badge-gray')+'">'+meta.label+'</span><span>'+meta.name+'</span></div><div class="curr-folder-meta"><span>'+byProgram.length+' subjects</span>'+assignmentBadge(byProgram)+'</div></div>'+years.map(y=>{
      const byYear=byProgram.filter(s=>s.yr===y);
      const semesters=[...new Set(byYear.map(s=>s.sem))].sort((a,b)=>semOrder.indexOf(a)-semOrder.indexOf(b));
      return '<div class="prospectus-year"><div class="year-title"><span><i class="ti ti-folder-open"></i> '+yearLabel(y)+'</span><span class="assignment-summary">'+assignmentBadge(byYear)+'</span></div>'+semesters.map(sm=>{
        const bySem=byYear.filter(s=>s.sem===sm);
        return '<div class="semester-block"><div class="semester-title"><span><i class="ti ti-calendar"></i> '+semesterLabel(sm)+'</span><span class="assignment-summary"><span>'+bySem.length+' subjects</span>'+assignmentBadge(bySem,sm)+'</span></div>'+renderSubjectRows(bySem)+'</div>';
      }).join('')+'</div>';
    }).join('')+'</div>';
  }).join('');
}

function startTeacherDrag(ev,facId){draggedFacultyId=facId;draggedSection='';ev.dataTransfer.setData('text/plain',String(facId));ev.dataTransfer.effectAllowed='copy';}
function clearSubjectDrop(ev){ev.currentTarget.classList.remove('drop-ready','drop-blocked');}
function handleSubjectDragOver(ev,subjId){
  const facId=draggedFacultyId||+ev.dataTransfer.getData('text/plain');
  const fac=db.faculty.find(f=>f.id===facId);
  const subj=db.subjects.find(s=>s.id===subjId);
  if(!fac||!subj)return;
  ev.preventDefault();
  ev.currentTarget.classList.toggle('drop-ready',canTeachProgram(fac,subj.prog));
  ev.currentTarget.classList.toggle('drop-blocked',!canTeachProgram(fac,subj.prog));
}
function assignSubjectToFaculty(facId,subjId,section=''){
  const fac=db.faculty.find(f=>f.id===facId);
  const subj=db.subjects.find(s=>s.id===subjId);
  if(!fac||!subj){alert('Invalid teacher or subject.');return false;}
  if(!canTeachProgram(fac,subj.prog)){alert(fac.ln+', '+fac.fn+' cannot teach subjects from '+programName(subj.prog)+'.');return false;}
  if(db.assignments.find(a=>a.facId===facId&&a.subjId===subjId&&a.section===section)){alert('Already assigned to '+section+'.');return false;}
  const curUnits=getFacultyUnits(facId,subj.sem);
  const mx=getFacultyMaxUnits(fac);
  const after=curUnits+subj.lec+subj.lab;
  if(after>mx){
    alert(`Cannot assign: ${fac.ln}, ${fac.fn} would exceed their maximum load of ${mx} units (would have ${after} units in ${semesterLabel(subj.sem)}).`);
    return false;
  }
  db.assignments.push({id:Date.now(),facId,subjId,section});
  renderLoadPage();renderFaculty();renderCurriculum();
  return true;
}
function dropTeacherOnSubject(ev,subjId,section){
  ev.preventDefault();clearSubjectDrop(ev);
  const facId=draggedFacultyId||+ev.dataTransfer.getData('text/plain');
  draggedSection=section;
  draggedFacultyId=null;
  assignSubjectToFaculty(facId,subjId,section);
}
function deleteSubject(id){
  if(!confirm('Remove this subject?'))return;
  db.subjects=db.subjects.filter(s=>s.id!==id);
  db.assignments=db.assignments.filter(a=>a.subjId!==id);
  renderCurriculum();updateMetrics();
}
function saveSubject(){
  const code=document.getElementById('s-code').value.trim();
  const title=document.getElementById('s-title').value.trim();
  const prog=document.getElementById('s-prog').value;
  if(!code||!title||!prog){alert('Fill in code, title, and program.');return;}
  db.subjects.push({
    id:Date.now(),code,title,prog,
    yr:+document.getElementById('s-yr').value,
    sem:document.getElementById('s-sem').value,
    lec:+document.getElementById('s-lec').value,
    lab:+document.getElementById('s-lab').value,
    lecRoomType:document.getElementById('s-lecroom').value||'Classroom',
    labRoomType:document.getElementById('s-labroom').value||''
  });
  closeModal('modal-addsubj');renderCurriculum();updateMetrics();
}

