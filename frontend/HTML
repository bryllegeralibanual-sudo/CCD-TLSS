function renderFaculty(search=''){
  const progF=document.getElementById('fac-prog-filter').value;
  let list=db.faculty;
  if(search)list=list.filter(f=>(f.ln+' '+f.fn).toLowerCase().includes(search.toLowerCase()));
  if(progF)list=list.filter(f=>canTeachProgram(f,progF));
  const tb=document.getElementById('faculty-table');
  if(!list.length){tb.innerHTML='<div class="card" style="text-align:center;padding:32px;color:var(--color-text-secondary)">No faculty found.</div>';return;}
  const order=db.programs.map(p=>p.code);
  const groups=[...new Set(list.map(f=>f.prog))].sort((a,b)=>order.indexOf(a)-order.indexOf(b));
  tb.innerHTML=groups.map(code=>{
    const meta=PROGRAM_META[code]||{label:code,name:code};
    const people=list.filter(f=>f.prog===code);
    return '<div class="group-heading"><h3><span class="badge '+(PROG_BADGE[code]||'badge-gray')+'">'+meta.label+'</span> '+meta.name+'</h3><span style="font-size:12px;color:var(--color-text-secondary)">'+people.length+' faculty</span></div><div class="faculty-program-grid">'+people.map(f=>{
      const sem=db.currentSem;
      const units=getFacultyUnits(f.id,sem);
      const mx=getFacultyMaxUnits(f);
      const pct=Math.min(100,Math.round(units/mx*100));
      const col=pct>100?'#A32D2D':pct>85?'#854F0B':'#3B6D11';
      const initials=(f.fn[0]||'')+(f.ln[0]||'');
      const colors=PROG_BG[f.prog]||['#F1EFE8','#5F5E5A'];
      // FIX #4: Display preferred time
      const prefLabels={'morning':'Morning','afternoon':'Afternoon','evening':'Evening','flexible':'Flexible'};
      const prefBadge=f.preferred?`<span class="badge badge-teal">${prefLabels[f.preferred]||'Flexible'}</span>`:'';
      return '<div class="faculty-card"><div class="faculty-photo" style="background:'+colors[0]+';color:'+colors[1]+'">'+initials+'</div><div class="faculty-info" style="flex:1"><h4>'+f.ln+', '+f.fn+'</h4><p>'+(f.spec||'No specialization listed')+'</p><div class="indicator-row"><span class="badge badge-gray">'+f.type+'</span><span class="badge '+(PROG_BADGE[f.prog]||'badge-gray')+'">'+facultyProgramLabel(f)+'</span>'+prefBadge+'</div><div style="margin-top:10px"><div style="font-size:11px;margin-bottom:3px;color:var(--color-text-secondary)">'+units+'/'+mx+' units ('+sem+' sem)</div><div class="load-bar"><div class="load-fill" style="width:'+pct+'%;background:'+col+'"></div></div></div><button class="btn btn-sm btn-danger" onclick="deleteFaculty('+f.id+')" style="margin-top:10px"><i class="ti ti-trash"></i></button></div></div>';
    }).join('')+'</div>';
  }).join('');
}
function deleteFaculty(id){
  if(!confirm('Remove this faculty member?'))return;
  db.faculty=db.faculty.filter(f=>f.id!==id);
  db.assignments=db.assignments.filter(a=>a.facId!==id);
  renderFaculty();updateMetrics();
}

